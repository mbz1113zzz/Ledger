# Copy to .env (one level up, next to stock-monitor/) and fill in.
# config.py loads ../.env via python-dotenv.

# ---------- Sources ----------
FINNHUB_API_KEY=
FINNHUB_ENABLE_NEWS=1
FINNHUB_ENABLE_EARNINGS=1
FINNHUB_ENABLE_ANALYST=0
FINNHUB_ENABLE_SENTIMENT=0

# ---------- Storage ----------
# DB_PATH=./data/events.db
# WATCHLIST_PATH=./watchlist.json

# ---------- Backup ----------
BACKUP_ENABLED=1
BACKUP_HOUR=3
BACKUP_MINUTE=30
BACKUP_KEEP_DAYS=14

# ---------- Enrichment (LLM summaries) ----------
# Pick one provider; DeepSeek wins if DEEPSEEK_API_KEY is set.
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
# ENRICH_PROVIDER=deepseek
# ENRICH_MODEL=deepseek-chat
ENRICH_ONLY_HIGH=1

# ---------- Push channels ----------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
BARK_URL=
FEISHU_WEBHOOK=

# ---------- Daily digest ----------
DIGEST_ENABLED=1
DIGEST_HOUR=13
DIGEST_MINUTE=0
DIGEST_LOOKBACK_HOURS=24

# ---------- IBKR realtime ----------
IBKR_ENABLED=1
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=42
IBKR_STARTUP_TIMEOUT_SEC=5

# ---------- SMC ----------
SMC_MAX_RISK_PCT=0.015
SMC_MIN_RR=2.0
SMC_TICK_SIZE=0.01

# ---------- Paper broker ----------
PAPER_ENABLED=1
PAPER_INITIAL_CASH=10000
PAPER_MAX_POSITIONS=5
PAPER_MAX_POSITION_PCT=0.20
PAPER_MAX_RISK_PER_TRADE_PCT=0.01
PAPER_MAX_HOLD_MIN=60
PAPER_BREAK_EVEN_ENABLED=1
PAPER_BREAK_EVEN_R=1.0
PAPER_MAX_DAY_DRAWDOWN_PCT=0.03
PAPER_MAX_GROSS_EXPOSURE_PCT=0.50
PAPER_MAX_OPEN_RISK_PCT=0.03
PAPER_SLIPPAGE_BPS=5
PAPER_COMMISSION_PER_SHARE=0.005
PAPER_COMMISSION_MIN=1.0
PAPER_EOD_HOUR_ET=15
PAPER_EOD_MINUTE_ET=50
REVIEW_HOUR_ET=16
REVIEW_MINUTE_ET=15

# ---------- Execution guardrails ----------
EXECUTION_MODE=paper
LIVE_TRADING_ENABLED=0
LIVE_EXECUTION_IMPLEMENTED=0
LIVE_READINESS_MIN_CLOSED_TRADES=20
LIVE_READINESS_MIN_WIN_RATE_PCT=50
LIVE_READINESS_MIN_AVG_RR=1.0
